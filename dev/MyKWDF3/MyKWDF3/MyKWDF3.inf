;
; MyKWDF3.inf
;

[Version]
Signature   = "$WINDOWS NT$"
Class       = System ; TODO: specify appropriate Class
ClassGuid   = {4d36e97d-e325-11ce-bfc1-08002be10318} ; TODO: specify appropriate ClassGuid
Provider    = %ManufacturerName%
CatalogFile = MyKWDF3.cat
DriverVer   = ; TODO: set DriverVer in stampinf property pages
PnpLockdown = 1

[DestinationDirs]
DefaultDestDir = 13

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
MyKWDF3.sys = 1,,

;*****************************************
; Install Section
;*****************************************

[Manufacturer]
%ManufacturerName% = Standard,NT$ARCH$.10.0...16299 ; %13% support introduced in build 16299

[Standard.NT$ARCH$.10.0...16299]
%MyKWDF3.DeviceDesc% = MyKWDF3_Device, Root\MyKWDF3 ; TODO: edit hw-id

[MyKWDF3_Device.NT]
CopyFiles = File_Copy

[File_Copy]
MyKWDF3.sys

;-------------- Service installation
[MyKWDF3_Device.NT.Services]
AddService = MyKWDF3,%SPSVCINST_ASSOCSERVICE%, MyKWDF3_Service_Inst

; -------------- MyKWDF3 driver install sections
[MyKWDF3_Service_Inst]
DisplayName    = %MyKWDF3.SVCDESC%
ServiceType    = 1               ; SERVICE_KERNEL_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\MyKWDF3.sys

[MyKWDF3_Device.NT.Wdf]
KmdfService = MyKWDF3, MyKWDF3_wdfsect

[MyKWDF3_wdfsect]
KmdfLibraryVersion = $KMDFVERSION$

[Strings]
SPSVCINST_ASSOCSERVICE = 0x00000002
ManufacturerName = "Zightch" ;TODO: Replace with your manufacturer name
DiskName = "MyKWDF3 Installation Disk"
MyKWDF3.DeviceDesc = "MyKWDF3 Device"
MyKWDF3.SVCDESC = "MyKWDF3 Service"
